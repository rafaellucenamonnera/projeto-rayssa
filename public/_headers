# Cache headers for production assets
# This file configures cache-control headers for static assets

# Cache hashed assets (JS/CSS with content hash) for 1 year
# These files have unique names when content changes, so they can be cached indefinitely
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Cache images with shorter duration
/*.jpg
  Cache-Control: public, max-age=2592000
/*.jpeg
  Cache-Control: public, max-age=2592000
/*.png
  Cache-Control: public, max-age=2592000
/*.webp
  Cache-Control: public, max-age=2592000
/*.svg
  Cache-Control: public, max-age=2592000
/*.ico
  Cache-Control: public, max-age=2592000

# Don't cache HTML files - they should always be fresh
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Cache fonts for 1 year
/*.woff
  Cache-Control: public, max-age=31536000, immutable
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
/*.ttf
  Cache-Control: public, max-age=31536000, immutable
/*.eot
  Cache-Control: public, max-age=31536000, immutable

# Default cache for root files
/*
  Cache-Control: public, max-age=3600
